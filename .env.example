# =============================================================================
# OpenFMR Module: Shared Health Record (SHR) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# =============================================================================

# --- PostgreSQL Configuration ------------------------------------------------
SHR_POSTGRES_DB=shr_hapi
SHR_POSTGRES_USER=shr_admin
SHR_POSTGRES_PASSWORD=change_me_in_production

# --- HAPI FHIR Server -------------------------------------------------------
# Host port mapping for the SHR FHIR server (container always listens on 8080).
SHR_FHIR_PORT=8084

# --- Ingestion Engine --------------------------------------------------------
# Host port mapping for the Ingestion Engine (container always listens on 8000).
SHR_INGESTION_PORT=8085

# --- Cross-Module Communication Timeout (seconds) ---------------------------
FHIR_REQUEST_TIMEOUT=30
